PORT=5000
CORS_ORIGIN=http://localhost:5173

# Production: comma-separated frontend URLs allowed to call the API
# CORS_ORIGIN=http://localhost:5173,https://your-site.vercel.app

# Contact form email (Gmail App Password required — see README)
CONTACT_EMAIL_TO=anujpatel299@gmail.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=anujpatel299@gmail.com
SMTP_PASS=

# --- Google Drive (resume + profile photo) ---
# Option A (recommended): folder + service account — drop files in Drive, site auto-picks them up
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_DRIVE_RESUME_FILENAME=Anuj_resume.pdf
GOOGLE_DRIVE_AVATAR_FILENAME=anuj.jpg
GOOGLE_DRIVE_SERVICE_ACCOUNT_KEY_FILE=./google-service-account.json

# Option B (simpler): individual public file IDs (share each file as "Anyone with the link")
# GOOGLE_DRIVE_RESUME_FILE_ID=
# GOOGLE_DRIVE_AVATAR_FILE_ID=
